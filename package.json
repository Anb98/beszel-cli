{
  "name": "beszel-cli",
  "version": "1.0.1",
  "description": "Read-only Beszel monitoring CLI for humans and AI agents — clean JSON output or colored TTY tables",
  "keywords": [
    "beszel",
    "monitoring",
    "observability",
    "cli",
    "homelab",
    "devops",
    "metrics",
    "systems",
    "agent",
    "json"
  ],
  "license": "MIT",
  "author": "Anb98 <aabdiel1998@gmail.com>",
  "homepage": "https://github.com/Anb98/beszel-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Anb98/beszel-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Anb98/beszel-cli/issues"
  },
  "type": "module",
  "bin": {
    "beszel": "./dist/cli.js"
  },
  "files": [
    "dist",
    "SKILL.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "yarn@4.17.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "gen:skill": "tsx scripts/gen-skill.ts",
    "check:skill": "tsx scripts/check-skill.ts",
    "prepack": "yarn build"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "ink": "5",
    "react": "18",
    "react-dom": "18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "18",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "9",
    "eslint-plugin-import": "^2.32.0",
    "ink-testing-library": "^4.0.0",
    "msw": "^2.14.6",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
